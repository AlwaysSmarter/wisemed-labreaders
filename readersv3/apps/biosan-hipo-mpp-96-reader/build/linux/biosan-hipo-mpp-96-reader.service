[Unit]
Description=WiseMED readersv3 Biosan HIPO MPP-96 Reader background service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/biosan-hipo-mpp-96-reader
ExecStart=/opt/biosan-hipo-mpp-96-reader/biosan-hipo-mpp-96-reader -config deployments/config.yaml -headless
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
